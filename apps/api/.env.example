APP_NAME=RentalRadar API
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rentalradar
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
TOKEN_ENCRYPTION_KEY=replace-with-fernet-key
SCRAPER_PROXY_URLS=
SCRAPER_PROXY_REDIS_KEY=rentalradar:proxy_pool
SCRAPER_PROXY_COOLDOWN_SECONDS=120
SCRAPER_REQUIRE_RESIDENTIAL_PROXY=false
BRIGHTDATA_PROXY_SERVER=
BRIGHTDATA_PROXY_SCHEME=http
BRIGHTDATA_PROXY_HOST=
BRIGHTDATA_PROXY_PORT=
BRIGHTDATA_PROXY_USERNAME=
BRIGHTDATA_PROXY_PASSWORD=
BROWSER_WORKER_MAX_CONCURRENT_BROWSERS=4
BROWSER_WORKER_METRICS_PORT=9108
BROWSER_ACTION_LOG_DIR=/tmp/rentalradar/browser-actions
SCRAPER_ALLOW_DETERMINISTIC_FALLBACK=false
LLM_PROVIDER=stub
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=8
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
APP_BASE_URL=http://localhost:3000
API_RATE_LIMIT_PER_MINUTE=120
FREE_TIER_PROPERTY_LIMIT=1
DEFAULT_MARKET_SCAN_DAYS=90
DEFAULT_COMP_LIMIT=12
MARKET_BOOKED_DATA_PROVIDER=none
AIRROI_API_KEY=
AIRROI_BASE_URL=https://api.airroi.com
AIRROI_RADIUS_MILES=5
AIRROI_PAGE_SIZE=50
DEMAND_SIGNALS_AUTO_REFRESH_ENABLED=true
DEMAND_SIGNAL_HTTP_TIMEOUT_SECONDS=12
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
TICKETMASTER_API_KEY=
TICKETMASTER_BASE_URL=https://app.ticketmaster.com/discovery/v2
TICKETMASTER_EVENT_RADIUS_MILES=35
FLIGHT_DEMAND_PROVIDER=none
FLIGHT_DEMAND_DEFAULT_AIRPORT_IATA=
FLIGHT_DEMAND_BUSY_ARRIVALS_PER_DAY=90
FLIGHT_DEMAND_MAX_DAYS=30
AVIATIONSTACK_API_KEY=
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1
SCRAPER_HEADLESS=false
SCRAPER_STEALTH=true
